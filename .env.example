# Copier vers `.env` à la racine du projet.

# SQLite : le fichier réel est `src/config/dev.db`. Avec `file:./dev.db`, `src/lib/db.js`
# réassocie automatiquement si `dev.db` n’existe pas à la racine (évite l’erreur SQLite 14 sous Next).
DATABASE_URL="file:./dev.db"

# Obligatoire pour /api/auth/login et /api/auth/register (JWT).
JWT_SECRET="remplace-par-une-chaîne-d-au-moins-32-caractères"
